/*
 * sev_gpu_manager.c
 * 
 * SEV GPU Manager - Kernel Module
 * Manages GPU sharing between multiple VMs via shared memory
 */

#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/fs.h>
#include <linux/cdev.h>
#include <linux/device.h>
#include <linux/uaccess.h>
#include <linux/mm.h>
#include <linux/vmalloc.h>
#include <linux/eventfd.h>
#include <linux/spinlock.h>
#include <linux/list.h>
#include <linux/sched.h>
#include <linux/delay.h>
#include <asm/page.h>
#include <asm/io.h>
#include "sev_gpu_manager.h"

MODULE_LICENSE("GPL");
MODULE_AUTHOR("Martin");
MODULE_DESCRIPTION("SEV GPU Manager - Shared memory GPU scheduling");
MODULE_VERSION("0.1");

/* Device stuff */
static dev_t sev_gpu_dev;
static struct cdev sev_gpu_cdev;
static struct class *sev_gpu_class;
static struct device *sev_gpu_device;

#define DEVICE_NAME "sev_gpu_manager"
#define CLASS_NAME "sev_gpu"

/* Shared memory region */
static struct {
    void *virt_addr;                    /* Kernel virtual address */
    phys_addr_t phys_addr;              /* Physical address */
    unsigned long size;                 /* Total size */
    sev_gpu_shmem_header_t *header;     /* Header pointer */
} shmem;

/* Per-VM context */
typedef struct {
    uint8_t vm_id;
    char vm_name[32];
    pid_t vm_pid;
    uint32_t priority;
    uint64_t total_gpu_ns;
    uint64_t start_time_ns;
    uint8_t state;
    struct eventfd_ctx *request_ctx;    /* eventfd for notifications */
    struct eventfd_ctx *grant_ctx;
    struct list_head list;
} vm_context_t;

/* Manager state */
static struct {
    spinlock_t lock;
    struct list_head vm_contexts;
    uint8_t num_vms;
    
    /* GPU state */
    uint8_t gpu_owner;
    uint64_t gpu_until_ns;
    
    /* Request queue */
    struct list_head request_queue;
    uint32_t request_count;
    
    /* Statistics */
    uint64_t context_switches;
    uint64_t total_requests;
} manager_state;

/* Helper: Get current time in nanoseconds */
static inline uint64_t get_time_ns(void) {
    struct timespec64 ts;
    ktime_get_real_ts64(&ts);
    return (uint64_t)ts.tv_sec * 1000000000ULL + ts.tv_nsec;
}

/* Allocate shared memory (non-private for SEV) */
static int allocate_shared_memory(void) {
    unsigned long total_size;
    unsigned long i;
    
    /* Calculate total size */
    total_size = PAGE_SIZE +                    /* Header page */
                 SEV_GPU_REQUEST_REGION_SIZE +
                 SEV_GPU_GRANT_REGION_SIZE +
                 ((unsigned long)SEV_GPU_DATA_REGION_SIZE * SEV_GPU_MAX_VMS);
    
    pr_info("sev_gpu: allocating %lu bytes for shared memory\n", total_size);
    
    /* For SEV, we need non-private (shared) pages
     * Use __GFP_SHARED flag if available, otherwise regular allocation works
     * The host/hypervisor will mark pages as non-private
     */
    
    /* Use vmalloc for large contiguous region */
    shmem.virt_addr = vmalloc(total_size);
    if (!shmem.virt_addr) {
        pr_err("sev_gpu: failed to allocate %lu bytes\n", total_size);
        return -ENOMEM;
    }
    
    shmem.size = total_size;
    
    /* Get physical address of first page
     * For vmalloc'd memory, use vmalloc_to_page + pfn conversion
     */
    {
        struct page *page = vmalloc_to_page(shmem.virt_addr);
        if (page) {
            shmem.phys_addr = (phys_addr_t)page_to_pfn(page) << PAGE_SHIFT;
        } else {
            pr_warn("sev_gpu: could not get physical address\n");
            shmem.phys_addr = 0x200000000ULL;  /* Placeholder for SEV */
        }
    }
    
    pr_info("sev_gpu: shared memory allocated\n");
    pr_info("  Virtual: %p\n", shmem.virt_addr);
    pr_info("  Physical: 0x%llx\n", shmem.phys_addr);
    pr_info("  Size: %lu\n", shmem.size);
    
    /* Initialize header */
    shmem.header = (sev_gpu_shmem_header_t *)shmem.virt_addr;
    shmem.header->magic = 0xDEADBEEFCAFEBABE;
    shmem.header->version = 1;
    shmem.header->num_vms = 0;
    
    /* Set up region offsets */
    shmem.header->request_region_off = PAGE_SIZE;
    shmem.header->request_region_size = SEV_GPU_REQUEST_REGION_SIZE;
    
    shmem.header->grant_region_off = 
        shmem.header->request_region_off + SEV_GPU_REQUEST_REGION_SIZE;
    shmem.header->grant_region_size = SEV_GPU_GRANT_REGION_SIZE;
    
    shmem.header->data_region_off = 
        shmem.header->grant_region_off + SEV_GPU_GRANT_REGION_SIZE;
    shmem.header->data_region_size = SEV_GPU_DATA_REGION_SIZE;
    
    /* Set up per-VM data offsets */
    for (i = 0; i < SEV_GPU_MAX_VMS; i++) {
        shmem.header->vm_data_offset[i] = 
            shmem.header->data_region_off + (i * SEV_GPU_DATA_REGION_SIZE);
        shmem.header->vm_data_size[i] = SEV_GPU_DATA_REGION_SIZE;
    }
    
    return 0;
}

/* Free shared memory */
static void free_shared_memory(void) {
    if (shmem.virt_addr) {
        vfree(shmem.virt_addr);
        shmem.virt_addr = NULL;
    }
}

/* Register a VM with the manager */
static vm_context_t *register_vm(const sev_gpu_ioctl_register_vm_t *reg) {
    vm_context_t *vm;
    unsigned long flags;
    
    if (reg->vm_id >= SEV_GPU_MAX_VMS) {
        pr_err("sev_gpu: invalid VM ID %d\n", reg->vm_id);
        return NULL;
    }
    
    vm = kzalloc(sizeof(*vm), GFP_KERNEL);
    if (!vm)
        return NULL;
    
    vm->vm_id = reg->vm_id;
    strncpy(vm->vm_name, reg->vm_name, sizeof(vm->vm_name) - 1);
    vm->vm_pid = reg->vm_pid;
    vm->priority = 128;
    vm->state = GPU_STATUS_IDLE;
    vm->start_time_ns = get_time_ns();
    
    spin_lock_irqsave(&manager_state.lock, flags);
    list_add(&vm->list, &manager_state.vm_contexts);
    manager_state.num_vms++;
    shmem.header->num_vms = manager_state.num_vms;
    spin_unlock_irqrestore(&manager_state.lock, flags);
    
    pr_info("sev_gpu: registered VM %d (%s, pid=%d)\n", 
            reg->vm_id, reg->vm_name, reg->vm_pid);
    
    return vm;
}

/* Find VM context by ID */
static vm_context_t *find_vm(uint8_t vm_id) {
    vm_context_t *vm;
    list_for_each_entry(vm, &manager_state.vm_contexts, list) {
        if (vm->vm_id == vm_id)
            return vm;
    }
    return NULL;
}

/* File operations */

static int sev_gpu_open(struct inode *inode, struct file *filp) {
    pr_debug("sev_gpu: device opened\n");
    return 0;
}

static int sev_gpu_release(struct inode *inode, struct file *filp) {
    pr_debug("sev_gpu: device closed\n");
    return 0;
}

static int sev_gpu_mmap(struct file *filp, struct vm_area_struct *vma) {
    unsigned long vsize;
    unsigned long num_pages;
    unsigned long i;
    struct page *page;
    int ret;
    
    pr_debug("sev_gpu: mmap request\n");
    
    if (!shmem.virt_addr) {
        pr_err("sev_gpu: shared memory not allocated\n");
        return -EINVAL;
    }
    
    /* Calculate size */
    vsize = vma->vm_end - vma->vm_start;
    
    if (vsize > shmem.size) {
        pr_err("sev_gpu: mmap size %lu exceeds available %lu\n", 
               vsize, shmem.size);
        return -EINVAL;
    }
    
    /* Calculate number of pages */
    num_pages = vsize >> PAGE_SHIFT;
    
    pr_debug("sev_gpu: mapping %lu pages (vsize=%lu)\n", num_pages, vsize);
    
    /* Map pages individually using vm_insert_page (more reliable than remap_vmalloc_range) */
    for (i = 0; i < num_pages; i++) {
        page = vmalloc_to_page((void *)shmem.virt_addr + (i << PAGE_SHIFT));
        if (!page) {
            pr_err("sev_gpu: vmalloc_to_page failed for page %lu\n", i);
            return -EINVAL;
        }
        
        ret = vm_insert_page(vma, vma->vm_start + (i << PAGE_SHIFT), page);
        if (ret) {
            pr_err("sev_gpu: vm_insert_page failed for page %lu (ret=%d)\n", i, ret);
            return ret;
        }
    }
    
    pr_info("sev_gpu: mmap successful (size=%lu, pages=%lu)\n", vsize, num_pages);
    return 0;
}

/* ioctl handler */
static long sev_gpu_ioctl(struct file *filp, unsigned int cmd, unsigned long arg) {
    int ret = 0;
    void __user *argp = (void __user *)arg;
    
    pr_debug("sev_gpu: ioctl cmd=0x%x\n", cmd);
    
    switch (cmd) {
    case SEV_GPU_IOC_REGISTER_VM: {
        sev_gpu_ioctl_register_vm_t reg;
        if (copy_from_user(&reg, argp, sizeof(reg))) {
            return -EFAULT;
        }
        if (!register_vm(&reg)) {
            return -ENOMEM;
        }
        break;
    }
    
    case SEV_GPU_IOC_GET_SHMEM: {
        sev_gpu_ioctl_get_shmem_t shmem_info;
        shmem_info.phys_addr = shmem.phys_addr;
        shmem_info.size = shmem.size;
        if (copy_to_user(argp, &shmem_info, sizeof(shmem_info))) {
            return -EFAULT;
        }
        pr_debug("sev_gpu: returned shmem phys=0x%llx size=%llu\n",
                shmem_info.phys_addr, shmem_info.size);
        break;
    }
    
    case SEV_GPU_IOC_REQUEST_GPU: {
        sev_gpu_ioctl_request_gpu_t req;
        vm_context_t *vm;
        if (copy_from_user(&req, argp, sizeof(req))) {
            return -EFAULT;
        }
        vm = find_vm(req.vm_id);
        if (!vm) {
            return -EINVAL;
        }
        pr_info("sev_gpu: GPU request from VM%d for %u us\n",
                req.vm_id, req.duration_us);
        break;
    }
    
    case SEV_GPU_IOC_RELEASE_GPU: {
        sev_gpu_ioctl_release_gpu_t rel;
        if (copy_from_user(&rel, argp, sizeof(rel))) {
            return -EFAULT;
        }
        pr_info("sev_gpu: GPU release from VM%d\n", rel.vm_id);
        break;
    }
    
    default:
        pr_warn("sev_gpu: unknown ioctl cmd=0x%x\n", cmd);
        return -ENOTTY;
    }
    
    return ret;
}

static const struct file_operations sev_gpu_fops = {
    .owner = THIS_MODULE,
    .open = sev_gpu_open,
    .release = sev_gpu_release,
    .mmap = sev_gpu_mmap,
    .unlocked_ioctl = sev_gpu_ioctl,
    .compat_ioctl = sev_gpu_ioctl,
};

/* Module init */
static int __init sev_gpu_init(void) {
    int ret;
    
    pr_info("sev_gpu: module loading\n");
    
    /* Allocate shared memory */
    ret = allocate_shared_memory();
    if (ret) {
        pr_err("sev_gpu: failed to allocate shared memory\n");
        return ret;
    }
    
    /* Initialize manager state */
    spin_lock_init(&manager_state.lock);
    INIT_LIST_HEAD(&manager_state.vm_contexts);
    INIT_LIST_HEAD(&manager_state.request_queue);
    manager_state.num_vms = 0;
    manager_state.gpu_owner = 0xFF;  /* No owner initially */
    
    /* Allocate character device */
    ret = alloc_chrdev_region(&sev_gpu_dev, 0, 1, DEVICE_NAME);
    if (ret) {
        pr_err("sev_gpu: failed to allocate chrdev region\n");
        goto err_chrdev;
    }
    
    /* Create device file */
    cdev_init(&sev_gpu_cdev, &sev_gpu_fops);
    sev_gpu_cdev.owner = THIS_MODULE;
    ret = cdev_add(&sev_gpu_cdev, sev_gpu_dev, 1);
    if (ret) {
        pr_err("sev_gpu: failed to add cdev\n");
        goto err_cdev_add;
    }
    
    /* Create device class */
    sev_gpu_class = class_create(CLASS_NAME);
    if (IS_ERR(sev_gpu_class)) {
        pr_err("sev_gpu: failed to create class\n");
        ret = PTR_ERR(sev_gpu_class);
        goto err_class;
    }
    
    /* Create device */
    sev_gpu_device = device_create(sev_gpu_class, NULL, sev_gpu_dev, NULL, DEVICE_NAME);
    if (IS_ERR(sev_gpu_device)) {
        pr_err("sev_gpu: failed to create device\n");
        ret = PTR_ERR(sev_gpu_device);
        goto err_device;
    }
    
    pr_info("sev_gpu: module loaded successfully\n");
    pr_info("sev_gpu: device /dev/%s created\n", DEVICE_NAME);
    return 0;
    
err_device:
    class_destroy(sev_gpu_class);
err_class:
    cdev_del(&sev_gpu_cdev);
err_cdev_add:
    unregister_chrdev_region(sev_gpu_dev, 1);
err_chrdev:
    free_shared_memory();
    return ret;
}

/* Module exit */
static void __exit sev_gpu_exit(void) {
    pr_info("sev_gpu: module unloading\n");
    
    device_destroy(sev_gpu_class, sev_gpu_dev);
    class_destroy(sev_gpu_class);
    cdev_del(&sev_gpu_cdev);
    unregister_chrdev_region(sev_gpu_dev, 1);
    
    free_shared_memory();
    
    pr_info("sev_gpu: module unloaded\n");
}

module_init(sev_gpu_init);
module_exit(sev_gpu_exit);
